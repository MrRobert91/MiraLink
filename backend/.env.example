ALLOWED_ORIGINS=*
PROFILE_DB_PATH=data/profiles.db
RESPONSES_DB_PATH=data/form_responses.db

# TTS (lectura en voz alta con motores de backend tipo Piper)
# Modelos .onnx horneados en la imagen (fuera del volumen). En Docker se fija a
# /app/models; en local apunta a donde tengas los modelos.
TTS_MODELS_DIR=models
TTS_CACHE_DIR=data/tts
TTS_CACHE_DB_PATH=data/tts_cache.db
TTS_CACHE_MAX_MB=500
TTS_CACHE_TTL_DAYS=120

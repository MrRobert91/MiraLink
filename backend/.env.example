# Orígenes permitidos para CORS. Lista separada por comas (esquema + host exactos,
# SIN barra final), o "*" para permitir todos.
# En producción, lista los dominios reales del frontend, p.ej.:
#   ALLOWED_ORIGINS=https://gemma4hackathon-v2-fdo1en.sliplane.app,https://miralink.app
ALLOWED_ORIGINS=*
PROFILE_DB_PATH=data/profiles.db
RESPONSES_DB_PATH=data/form_responses.db

# TTS (lectura en voz alta con motores de backend tipo Piper)
# NOTA: en Docker estas dos rutas las fija docker-compose.yml (apuntando al
# binario y los modelos horneados en la imagen) y tienen prioridad sobre este
# archivo. Los valores de abajo solo aplican a la ejecución local del backend.
# Binario de Piper: 'piper' si está en el PATH, o la ruta al ejecutable.
PIPER_BIN=piper
# Modelos .onnx (carpeta donde están los .onnx + .onnx.json).
TTS_MODELS_DIR=models
TTS_CACHE_DIR=data/tts
TTS_CACHE_DB_PATH=data/tts_cache.db
TTS_CACHE_MAX_MB=500
TTS_CACHE_TTL_DAYS=120
